{
  "name": "xyzw-token-manager",
  "version": "2.0.0",
  "type": "module",
  "description": "XYZW游戏Token管理器 - 支持Base64导入和WebSocket连接管理",
  "main": "src/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "testr": "node ./test/roleToken.js",
    "testd": "node ./test/token.js",
    "lint": "eslint src --ext .vue,.js,.ts --fix",
    "lint:check": "eslint src --ext .vue,.js,.ts",
    "format": "prettier --write \"src/**/*.{js,vue,ts,css,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,vue,ts,css,scss,json}\"",
    "type-check": "vue-tsc --noEmit",
    "analyze": "vite-bundle-analyzer dist",
    "clean": "rimraf dist node_modules/.vite",
    "prebuild": "npm run clean && npm run lint && npm run type-check",
    "postbuild": "npm run analyze",
    "serve": "vite preview --host",
    "verify": "node scripts/verify-optimization.js"
  },
  "dependencies": {
    "@arco-design/web-vue": "^2.57.0",
    "@vicons/ionicons5": "^0.12.0",
    "@vicons/material": "^0.12.0",
    "@vueuse/core": "^13.9.0",
    "axios": "^1.12.2",
    "crypto-js": "^4.2.0",
    "event-emitter3": "^1.0.4",
    "html2canvas": "^1.4.1",
    "iconv-lite": "^0.7.2",
    "idb": "^8.0.3",
    "lz4js": "^0.2.0",
    "moment": "^2.30.1",
    "naive-ui": "^2.43.1",
    "p-queue": "^7.4.1",
    "pinia": "^2.3.1",
    "vue": "^3.5.22",
    "vue-i18n": "^11.1.12",
    "vue-router": "^4.6.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.7.3",
    "@iconify-json/mdi": "^1.2.3",
    "@intlify/unplugin-vue-i18n": "^6.0.8",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^20.19.21",
    "@vitejs/plugin-basic-ssl": "^1.2.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.20",
    "jiti": "^2.6.1",
    "postcss": "^8.5.6",
    "rimraf": "^6.0.1",
    "rollup-plugin-visualizer": "^5.12.0",
    "sass": "^1.93.2",
    "terser": "^5.36.0",
    "typescript": "^5.9.3",
    "unocss": "^0.61.9",
    "unplugin-auto-import": "^19.3.0",
    "unplugin-vue-components": "^28.4.1",
    "unplugin-vue-router": "^0.8.8",
    "vite": "^5.4.11",
    "vite-bundle-analyzer": "^0.15.2",
    "vite-plugin-checker": "^0.8.0",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-inspect": "^0.8.7",
    "vite-plugin-pwa": "^0.21.1",
    "vue-tsc": "^2.1.10"
  },
  "keywords": [
    "vue",
    "vue3",
    "token-management",
    "websocket",
    "base64",
    "game-automation",
    "xyzw",
    "frontend",
    "pwa",
    "typescript"
  ],
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "author": "XYZW Team",
  "license": "CC-BY-NC-SA-4.0",
  "packageManager": "pnpm@10.19.0"
}
